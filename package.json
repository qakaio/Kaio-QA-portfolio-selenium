{
  "name": "kaio-qa-portfolio-selenium",
  "version": "1.0.0",
  "description": "Selenium WebDriver + JavaScript test automation framework for SauceDemo e-commerce site. Implements Page Object Model with Mocha/Chai.",
  "author": "Kaio Garcia <kaioqa@protonmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qakaio/Kaio-QA-portfolio-selenium.git"
  },
  "homepage": "https://github.com/qakaio/Kaio-QA-portfolio-selenium",
  "bugs": {
    "url": "https://github.com/qakaio/Kaio-QA-portfolio-selenium/issues"
  },
  "keywords": [
    "selenium",
    "webdriver",
    "test-automation",
    "qa-automation",
    "page-object-model",
    "mocha",
    "chai",
    "saucedemo",
    "allure-report"
  ],
  "scripts": {
    "test": "mocha tests/**/*.js",
    "test:headed": "HEADLESS=false mocha tests/**/*.js",
    "test:verbose": "mocha tests/**/*.js --reporter spec",
    "test:single": "mocha tests/login.spec.js",
    "test:allure": "mocha tests/**/*.js --reporter mocha-allure-reporter",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "devDependencies": {
    "@babel/preset-env": "^8.0.2",
    "@babel/register": "^8.0.1",
    "allure-commandline": "^2.30.0",
    "chai": "^5.1.0",
    "eslint": "^9.0.0",
    "mocha": "^10.4.0",
    "mocha-allure-reporter": "^1.4.0",
    "selenium-webdriver": "^4.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
